# Cloudflare Pages headers.
# Rule /* phải có Cache-Control no-store để ngăn CDN/browser cache HTML SPA routes.
# Rule /assets/* cụ thể hơn sẽ override với immutable cho static files có hash.

/*
  Cache-Control: no-store, max-age=0, must-revalidate
  Pragma: no-cache
  Expires: 0
  Content-Security-Policy: default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: https://*.trycloudflare.com https://static.cloudflareinsights.com https://api.alin.city https://*.alin.city https://alin.city; frame-src 'self' data: blob: https://*.trycloudflare.com https://*.alin.city https://alin.city; style-src 'self' 'unsafe-inline'; worker-src 'self' blob:; font-src 'self' data: https://cdn.jsdelivr.net https://tiles.openfreemap.org; connect-src 'self' https://cdn.jsdelivr.net https://*.trycloudflare.com wss://*.trycloudflare.com http://localhost:* ws://localhost:* wss://localhost:* https://ipapi.co https://api.alin.city wss://api.alin.city wss://alin-social.alin.city https://*.alin.city wss://*.alin.city https://alin.city wss://alin.city https://www.alin.city wss://www.alin.city https://nominatim.openstreetmap.org https://api.open-meteo.com https://tiles.openfreemap.org; img-src 'self' data: blob: https://* http://localhost:*;
  X-Frame-Options: ALLOWALL
  X-Content-Type-Options: nosniff
  Access-Control-Allow-Origin: *

/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff
