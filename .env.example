# Backend Server Port (chung cho tất cả dự án)
PORT=3000

# Frontend Dev Server Port (mỗi dự án 1 port khác nhau)
FRONTEND_PORT=3001

# API và WebSocket URL - trỏ về backend server
VITE_EXTERNAL_API_URL=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000

# Disable HMR để tránh xung đột WebSocket
DISABLE_HMR=true
